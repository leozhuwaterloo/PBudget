# Copy to ~/.pbudget-ios.env (chmod 600) — NEVER commit. Sourced by ios-release.sh.
#
# App Store Connect API key (one-time): App Store Connect → Users and Access →
# Integrations → App Store Connect API → generate a key with the "App Manager" role.
# Download the .p8 ONCE (you can't re-download it) and note the Key ID + Issuer ID.
ASC_KEY_ID=XXXXXXXXXX
ASC_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ASC_KEY_PATH="$HOME/.appstoreconnect/private_keys/AuthKey_XXXXXXXXXX.p8"

# Your 10-char Apple Developer Team ID (App Store Connect → Membership Details).
ASC_TEAM_ID=XXXXXXXXXX

# Ephemeral clone source (ssh or https).
PB_REPO="git@github.com:leozhuwaterloo/PlaidBudget.git"

# Optional overrides:
# PB_MARKETING_VERSION=1.0            # user-facing version string
# PB_EXPORT_METHOD=app-store-connect  # older Xcode (<15.3) wants: app-store
# PB_KEEP=1                           # keep the temp build dir instead of deleting
