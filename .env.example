# --- Database -------------------------------------------------------------
# Local dev (SQLite). For prod, swap schema.prisma provider to "postgresql"
# and point this at postgres-ai (see Setups deploy step).
DATABASE_URL="file:./dev.db"

# --- App ------------------------------------------------------------------
# Public base URL, used in verification email links.
APP_URL="http://localhost:5300"
# 32-byte key (base64) for AES-256-GCM encryption of Plaid access tokens.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
APP_ENCRYPTION_KEY=""

# --- Plaid ----------------------------------------------------------------
PLAID_CLIENT_ID=""
PLAID_SECRET=""
# sandbox | development | production
PLAID_ENV="sandbox"
# ISO country codes for Link (comma-separated), e.g. CA or US
PLAID_COUNTRY_CODES="CA"

# --- Stripe (billing: Free/Pro/Max Plaid-connection tiers) ----------------
# Tiers are priced per Plaid CONNECTION (a bank login): Free = 1 (no card),
# Pro = 5 ($5/mo), Max = 20 ($15/mo). Create two flat recurring prices in the
# Stripe dashboard and paste their price ids below (STRIPE_PRICE_ID is retired).
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_PRO=""
STRIPE_PRICE_MAX=""

# --- Email (verification) -------------------------------------------------
# If SMTP_HOST is unset, verification links are logged to the server console.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="PBudget <no-reply@pbudget.local>"
