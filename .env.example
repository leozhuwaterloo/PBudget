# --- Database -------------------------------------------------------------
# Local dev (SQLite). For prod, swap schema.prisma provider to "postgresql"
# and point this at postgres-ai (see Setups deploy step).
DATABASE_URL="file:./dev.db"

# --- App ------------------------------------------------------------------
# Public base URL, used in verification email links.
APP_URL="http://localhost:5300"
# 32-byte key (base64) for AES-256-GCM encryption of Plaid access tokens.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
APP_ENCRYPTION_KEY=""

# --- Plaid ----------------------------------------------------------------
PLAID_CLIENT_ID=""
PLAID_SECRET=""
# sandbox | development | production
PLAID_ENV="sandbox"
# ISO country codes for Link (comma-separated), e.g. CA or US
PLAID_COUNTRY_CODES="CA"

# --- Stripe (billing: Free/Pro/Max Plaid-connection tiers) ----------------
# Tiers are priced per Plaid CONNECTION (a bank login): Free = 1 (no card),
# Pro = 5 ($5/mo), Max = 20 ($15/mo). Create two flat recurring prices in the
# Stripe dashboard and paste their price ids below (STRIPE_PRICE_ID is retired).
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_PRO=""
STRIPE_PRICE_MAX=""

# --- Native store IAP (iOS StoreKit / Google Play Billing) ----------------
# Platform-split billing: the WEB uses Stripe (above); inside the iOS/Android app,
# Apple/Google mandate their own in-app billing, so native uses store IAP with
# SELF-HOSTED receipt validation. DORMANT until the two product ids are set (native
# purchase UI hides / falls back to a web link). Price the store products ~30% above
# the web tiers to offset the store cut (set the price in each console, not here).
# Use the SAME product-id string on both App Store Connect and Play Console.
IAP_PRODUCT_PRO=""   # e.g. com.ppvnx.pbudget.pro.monthly  -> plan "pro"
IAP_PRODUCT_MAX=""   # e.g. com.ppvnx.pbudget.max.monthly  -> plan "max"
# App identifiers (default to capacitor.config.ts appId com.ppvnx.pbudget if unset).
APPLE_BUNDLE_ID=""       # bundle id stamped in the StoreKit signed transaction
ANDROID_PACKAGE_NAME=""  # Play package name, for the Play Developer API lookup
# iOS: no secret needed — the StoreKit signed-transaction JWS + App Store Server
# Notifications V2 are verified offline against the pinned Apple Root CA (lib/iap.ts).
# Android: a Google Cloud service-account JSON (with the Play Developer API granted)
# used to server-verify purchases + handle RTDN. Paste the whole downloaded JSON.
GOOGLE_PLAY_SA_JSON=""

# --- Email (verification) -------------------------------------------------
# If SMTP_HOST is unset, verification links are logged to the server console.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="PBudget <no-reply@pbudget.local>"
