generator client {
  provider = "prisma-client-js"
}

// ponytail: provider is sqlite for local dev. For prod (postgres-ai) the deploy
// step swaps this to "postgresql" — only the provider + DATABASE_URL change, no
// query rewrites (CLAUDE.md). Json is stored as String for provider-agnosticism.
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---- Accounts / auth / billing -------------------------------------------

model User {
  id                   String    @id @default(cuid())
  email                String    @unique
  passwordHash         String
  emailVerified        DateTime?
  createdAt            DateTime  @default(now())

  // billing (V2: tier per Plaid connection — free|pro|max, set by the Stripe
  // webhook from the subscription price id, FR10). subscriptionStatus/ids stay
  // for the Stripe round-trip; the legacy $1/account quantity model is retired.
  plan                 String    @default("free") // free | pro | max
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  subscriptionStatus   String? // active | trialing | past_due | canceled | ...

  // Admin: exempt from the Plaid-connection limit (unlimited, no subscription).
  isAdmin              Boolean   @default(false)

  locale String? // "en" | "zh-Hans"; null = en

  sessions           Session[]
  verificationTokens EmailVerificationToken[]
  passwordResetTokens PasswordResetToken[]
  items              PlaidItem[]
  categories         TransactionCategory[]
  vendors            Vendor[]
}

model Session {
  token     String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model EmailVerificationToken {
  token     String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now()) // for 1/min email throttle

  @@index([userId])
}

model PasswordResetToken {
  token     String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now()) // for 1/min email throttle

  @@index([userId])
}

// ---- Plaid domain (ported from Portfolio's App/plaid/models.py) -----------

model PlaidInstitution {
  institutionId String      @id
  name          String
  primaryColor  String?
  url           String?
  logo          String?
  lastUpdated   DateTime    @updatedAt
  items         PlaidItem[]
}

model PlaidItem {
  itemId             String           @id
  userId             String
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  institutionId      String
  institution        PlaidInstitution @relation(fields: [institutionId], references: [institutionId], onDelete: Cascade)
  accessToken        String // AES-256-GCM encrypted Plaid access token
  createdAt          DateTime         @default(now()) // FR10 downgrade ordering: first `limit` items by connection date keep syncing
  lastUpdated        DateTime         @updatedAt
  lastForceRefreshed DateTime
  accounts           PlaidAccount[]

  @@index([userId])
  @@index([institutionId])
}

model PlaidAccount {
  accountId       String             @id
  itemId          String
  item            PlaidItem          @relation(fields: [itemId], references: [itemId], onDelete: Cascade)
  name            String
  officialName    String?
  accountType     String
  accountSubtype  String?
  available       Decimal?
  current         Decimal?
  limit           Decimal?
  isoCurrencyCode String?
  lastUpdated     DateTime           @updatedAt
  transactions    PlaidTransaction[]
  vendorConditions VendorCondition[] // back-relation for VendorCondition.accountId (FR1)

  @@index([itemId])
}

model PlaidTransaction {
  transactionId        String       @id
  accountId            String
  account              PlaidAccount @relation(fields: [accountId], references: [accountId], onDelete: Cascade)
  amount               Decimal
  isoCurrencyCode      String?
  category             String? // JSON text: Plaid personal_finance_category + legacy categories
  datetime             DateTime
  name                 String
  merchantName         String?
  paymentChannel       String
  pending              Boolean
  pendingTransactionId String?
  // ponytail: original used an ML model (PlaidTransactionMeta.predicted_category),
  // not portable. We derive this from Plaid's personal_finance_category at sync.
  predictedCategory    String?
  vendorId             String? // FR1: materialized winning-vendor match (null = unmatched/queue)
  lastUpdated          DateTime     @updatedAt

  @@index([accountId])
  @@index([vendorId])
}

model TransactionCategory {
  id                String  @id @default(cuid())
  userId            String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name              String
  budget            Decimal @default(0)
  excludeFromTotals Boolean @default(false) // FR4: keep off Dashboard totals (Income/Transfer/…)
  parentName        String? // subcategory parent (by name, like every other category ref); null = top-level. Capped at 2 levels.

  @@unique([userId, name])
}

// ---- Analysis domain (src/lib/analysis/*) ---------------------------------

// V2 vendor (FR1): a user-owned match rule. Ascending `priority` = match order;
// a vendor matches when ANY of its condition rows match. status/decidedAt are the
// retired approval model.
model Vendor {
  id           String            @id @default(cuid())
  userId       String
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String // display name
  link         String? // Google Maps entry (local vendor) or website (online) | null
  iconLink     String? // optional direct image URL for the icon; overrides link-derived favicon
  // Cached icon data URI. Derived from iconLink if set, else the favicon/Maps photo
  // of `link`. Column predates links (was bundled icons) but is now written again.
  icon         String?
  categoryName String? // optional DEFAULT category (FR3 fallback)
  priority     Int? // ascending = match order; NULL = legacy row, never matches
  // DEPRECATED (legacy approval model): read ONLY by F14's data migration. Do not
  // use in new code. Columns are dropped after the prod data migration is confirmed.
  status       String?
  decidedAt    DateTime?
  conditions   VendorCondition[]

  @@unique([userId, name])
  @@unique([userId, priority])
}

// One AND-row of a vendor (FR1): matches when ALL its set fields hold. Two-stage
// model: `role="match"` rows decide vendor IDENTITY (any match → the vendor claims
// the txn); `role="category"` rows refine the CATEGORY (first matching row by
// `order` → its categoryName, else the vendor default). A vendor with no match
// rows uses its category rows for identity too (the catch-all case).
model VendorCondition {
  id             String        @id @default(cuid())
  vendorId       String
  vendor         Vendor        @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  role           String        @default("category") // "match" (identity) | "category" (refine)
  order          Int // row order within its role; first matching category row decides category
  categoryName   String? // category outcome for a category row (ignored for match rows)
  nameOp         String? // contains | equals | starts_with | regex
  nameValue      String?
  merchantOp     String?
  merchantValue  String?
  amountMin      Decimal? // signed, Plaid convention (+ = outflow)
  amountMax      Decimal?
  accountId      String?
  account        PlaidAccount? @relation(fields: [accountId], references: [accountId], onDelete: SetNull)
  paymentChannel String? // online | in store | other
  plaidPrimary   String?
  plaidDetailed  String?

  @@index([vendorId])
}

// A manual split of one posted ungrouped transaction into N parts (FR5). The read
// model replaces the parent with its parts; the analyzer keeps evaluating the parent.
model TransactionSplit {
  id                  String      @id @default(cuid())
  userId              String
  parentTransactionId String      @unique // one split per transaction
  parts               SplitPart[]
}

model SplitPart {
  id           String           @id @default(cuid())
  splitId      String
  split        TransactionSplit @relation(fields: [splitId], references: [id], onDelete: Cascade)
  amount       Decimal // signed, same sign as parent; integer-cents sum == parent
  label        String?
  categoryName String? // optional override; unset → resolves through the parent's waterfall

  @@index([splitId])
}

model TransactionFlag {
  id            String    @id @default(cuid())
  userId        String
  rule          String // one of the four rule ids
  transactionId String? // exactly one of transactionId | mergeGroupId is set
  mergeGroupId  String?
  status        String    @default("open") // open | dismissed | resolved
  createdAt     DateTime  @default(now())
  resolvedAt    DateTime?

  @@unique([rule, transactionId])
  @@unique([rule, mergeGroupId])
  @@index([userId, status])
}

model MergeGroup {
  id           String   @id @default(cuid())
  userId       String
  status       String // auto | confirmed  (manual merges are born "confirmed")
  title        String // user-editable; defaults from primary leg
  vendorName   String? // normalized vendor of primary leg
  categoryName String? // effective category of primary leg (via categoryFor)
  date         DateTime // primary leg's date
  netAmount    Decimal // signed sum of legs (Plaid convention)
  currency     String?
  createdAt    DateTime @default(now())
  legs         MergeGroupLeg[]
}

model MergeGroupLeg {
  transactionId String     @id // a transaction belongs to at most ONE group
  groupId       String
  group         MergeGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

model DissolvedGroupMemo {
  id     String @id @default(cuid())
  userId String
  legKey String // sorted transactionIds joined with "|"

  @@unique([userId, legKey])
}

model CategoryMapping {
  id           String @id @default(cuid())
  userId       String
  plaidPrimary String // e.g. "FOOD_AND_DRINK"
  categoryName String // target user category name (TransactionCategory row ensured)

  @@unique([userId, plaidPrimary])
}
